{
  "domain": "build",
  "checks": [
    {
      "id": "MTB-001",
      "title": "Gradle build can compile Java",
      "severity": "critical",
      "required_files": ["build.gradle", "build.gradle.kts"],
      "signals": [
        "plugins.*java",
        "plugins.*java-library",
        "plugins.*org.springframework.boot",
        "java\\s*\\{",
        "toolchain",
        "sourceCompatibility",
        "targetCompatibility"
      ]
    },
    {
      "id": "MTB-005",
      "title": "Versions centralized in libs.versions.toml",
      "severity": "critical",
      "required_files": ["gradle/libs.versions.toml"],
      "signals": [
        "\\[versions\\]",
        "\\[plugins\\]",
        "\\[libraries\\]",
        "cucumber",
        "jacoco",
        "spring",
        "sonarqube"
      ]
    },
    {
      "id": "MTB-005.3",
      "title": "Spring managed in catalog (Boot + Actuator)",
      "severity": "minor",
      "required_files": ["gradle/libs.versions.toml"],
      "signals": ["springBoot", "springBootStarterActuator"]
    },
    {
      "id": "MTB-005.4",
      "title": "Publishing conventions present",
      "severity": "major",
      "required_files": ["build.gradle", "build.gradle.kts"],
      "signals": [
        "maven-publish",
        "publishing\\s*\\{",
        "Apache-2.0",
        "Apache License, Version 2.0",
        "staging"
      ]
    },
    {
      "id": "MTB-005.5",
      "title": "SonarQube managed in catalog and configured",
      "severity": "major",
      "required_files": ["gradle/libs.versions.toml", "build.gradle", "build.gradle.kts"],
      "signals": ["sonarqube", "sonar", "properties"]
    }
  ]
}

