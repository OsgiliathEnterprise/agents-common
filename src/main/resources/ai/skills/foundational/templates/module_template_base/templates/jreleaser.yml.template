environment:
  properties:
    gitRootSearch: false

project:
  name: {{PROJECT_NAME}}
  versionPattern: SEMVER
  description: {{PROJECT_DESCRIPTION}}
  copyright: {{COPYRIGHT}}
  authors:
    - {{AUTHOR_NAME}}
  license: Apache-2.0
  inceptionYear: {{INCEPTION_YEAR}}
  java:
    groupId: {{GROUP_ID}}
    version: 21
  links:
    homepage: {{HOMEPAGE_URL}}
  snapshot:
    pattern: .*-SNAPSHOT

release:
  github:
    enabled: true
    draft: true
    skipRelease: false
    skipTag: true
    overwrite: true

signing:
  active: ALWAYS
  armored: true
  verify: false

deploy:
  maven:
    mavenCentral:
      sonatype:
        active: RELEASE
        url: https://central.sonatype.com/api/v1/publisher
        stagingRepositories:
          - build/staging-deploy
        applyMavenCentralRules: true
        verifyPom: true

